# .env.example - Copie para .env.local e configure com seus valores
# NUNCA fazer commit de .env com valores reais!

# ═══════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════
# Para desenvolvimento: PortalEstudos.db
# Para produção: use PostgreSQL ou Azure SQL Database
DB_CONNECTION_STRING=PortalEstudos.db

# ═══════════════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════════════════════
# IMPORTANTE: Gere uma chave aleatória de pelo menos 32 caracteres
# Usar comando: dotnet user-secrets set "JWT_SECRET_KEY" "sua-chave-muito-segura"
JWT_SECRET_KEY=seu-jwt-secret-key-muito-seguro-aqui-32-caracteres-minimo

# ═══════════════════════════════════════════════════════════
# CORS Configuration
# ═══════════════════════════════════════════════════════════
# Produção: https://seu-dominio.com.br
# Desenvolvimento: http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ═══════════════════════════════════════════════════════════
# AMBIENTE
# ═══════════════════════════════════════════════════════════
ASPNETCORE_ENVIRONMENT=Development

# ═══════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════
# minimal, debug, information: warning, error, critical
LOG_LEVEL=Information

# ═══════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ═══════════════════════════════════════════════════════════
# SECURITY HEADERS
# ═══════════════════════════════════════════════════════════
ENABLE_HSTS=true
ENABLE_CSP=true
